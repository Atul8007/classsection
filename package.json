{
  "name": "classsection",
  "version": "2.0.0",
  "description": "Lightweight utility and CLI for adding custom CSS classes to UI sections. Zero-dependency core. AI-agent friendly.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.mjs",
      "types": "./src/index.d.ts"
    }
  },
  "bin": {
    "classsection": "bin/cli.js"
  },
  "sideEffects": false,
  "scripts": {
    "start": "node bin/cli.js",
    "postinstall": "node scripts/postinstall.js",
    "test": "node test/library.test.js && node test/core.test.js && node test/transformer.test.js && node test/size.test.js"
  },
  "keywords": [
    "shopify",
    "theme",
    "liquid",
    "sections",
    "cli",
    "custom-class",
    "class-names",
    "css",
    "bem",
    "ai-agent",
    "bulk-transform",
    "react",
    "vue",
    "jsx"
  ],
  "author": "Atul8007",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atul8007/classsection.git"
  },
  "homepage": "https://github.com/Atul8007/classsection#readme",
  "bugs": {
    "url": "https://github.com/Atul8007/classsection/issues"
  },
  "files": [
    "src/",
    "bin/",
    "core/",
    "features/",
    "transformers/",
    "utils/",
    "scripts/",
    "examples/",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "prettier": "^3.2.5"
  }
}
